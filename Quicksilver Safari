// ==UserScript==
// @name         Quicksilver Safari
// @namespace    http://tampermonkey.net/
// @version      3.1
// @description  Safari-friendly browsing accelerator: static asset cache, just-in-time preconnect, same-origin navigation warming, and font-display swap.
// @author       Codex
// @match        *://*/*
// @noframes
// @grant        GM_registerMenuCommand
// @run-at       document-start
// ==/UserScript==

(function () {
    'use strict';

    const EVENT_PREFIX = '__quicksilver_safari__';
    const injectId = '__quicksilver_safari_runtime__';

    function dispatchRuntimeCommand(type) {
        window.dispatchEvent(new CustomEvent(EVENT_PREFIX + ':command', {
            detail: { type: type }
        }));
    }

    function installMenuCommands() {
        if (typeof GM_registerMenuCommand !== 'function') return;

        GM_registerMenuCommand('Quicksilver: Purge Asset Cache', () => {
            dispatchRuntimeCommand('purge-cache');
        });

        GM_registerMenuCommand('Quicksilver: Show Cache Stats', () => {
            dispatchRuntimeCommand('show-stats');
        });
    }

    function installConsoleFallback() {
        const api = {
            purgeCache: function () {
                dispatchRuntimeCommand('purge-cache');
            },
            showStats: function () {
                dispatchRuntimeCommand('show-stats');
            }
        };

        Object.defineProperty(window, '__quicksilverSafari', {
            value: api,
            configurable: true
        });
    }

    function injectRuntime() {
        if (document.getElementById(injectId)) return;

        const runtimeSource = '(' + function () {
            'use strict';

            const CACHE_NAME = 'tm-smart-lru-safari-v1';
            const MAX_ITEMS = 1000;
            const PRUNE_CHUNK = 50;
            const METADATA_KEY = 'tm-cache-lru-metadata-safari';
            const STATS_KEY = '__quicksilver_safari_stats__';
            const EVENT_PREFIX = '__quicksilver_safari__';
            const FLUSH_DELAY = 2000;
            const STATS_FLUSH_DELAY = 2000;
            const SPECULATION_SCRIPT_ID = '__quicksilver_safari_speculationrules__';
            const MAX_REVALIDATE_URLS = 256;
            const MAX_WARMED_URLS = 256;
            const FONT_OBSERVER_LIFETIME_MS = 30000;

            const CACHEABLE_EXTENSIONS = /\.(js|css|woff2?|ttf|otf|eot|png|jpe?g|gif|svg|ico|webp|avif|bmp|wasm)(\?|$)/i;
            const SKIP_URL_PATTERNS = [
                /\/api\//i, /\/graphql/i, /\/feed/i, /\/rss/i, /\/json/i, /\/ws\//i,
                /\.json(\?|$)/i, /\.html?(\?|$)/i, /\.xml(\?|$)/i,
                /\bservice-worker\b/i, /\bmanifest\b.*\.js/i,
                /\.m3u8(\?|$)/i, /\.mpd(\?|$)/i
            ];
            const NO_STORE = /\bno-store\b/i;
            const FORCE_REVALIDATE = /\b(no-cache|must-revalidate)\b/i;
            const CACHEABLE_CONTENT_TYPES = /^(text\/css|text\/javascript|application\/javascript|application\/x-javascript|image\/|font\/|application\/font|application\/x-font|application\/wasm)/i;

            function getClosestLinkTarget(target) {
                if (!(target instanceof Element)) return null;
                return target.closest('a[href]');
            }

            function getConnectionInfo() {
                const conn = navigator.connection;
                return {
                    effectiveType: conn && conn.effectiveType ? conn.effectiveType : 'unknown',
                    saveData: !!(conn && conn.saveData)
                };
            }

            function getRevalidateTTL() {
                const info = getConnectionInfo();
                if (info.saveData) return 7200000;
                switch (info.effectiveType) {
                    case '4g': return 1800000;
                    case '3g': return 3600000;
                    case '2g':
                    case 'slow-2g': return 7200000;
                    default: return 3600000;
                }
            }

            function hasUsableCacheApi() {
                return window.isSecureContext && typeof caches !== 'undefined';
            }

            let metadataMap = new Map();
            let metadataDirty = false;
            let flushTimer = null;
            let statsDirty = false;
            let statsFlushTimer = null;
            const forceRevalidateUrls = new Set();
            let cacheHits = 0;
            let cacheMisses = 0;
            let speculationRulesInstalled = false;

            function loadMetadata() {
                try {
                    const raw = localStorage.getItem(METADATA_KEY);
                    if (!raw) return;
                    const parsed = JSON.parse(raw);
                    Object.keys(parsed).forEach(function (key) {
                        metadataMap.set(key, parsed[key]);
                    });
                } catch (_) {}
            }

            function persistStats() {
                try {
                    localStorage.setItem(STATS_KEY, JSON.stringify({
                        hits: cacheHits,
                        misses: cacheMisses,
                        ttlMs: getRevalidateTTL(),
                        connection: getConnectionInfo().effectiveType,
                        secureContext: window.isSecureContext,
                        cacheApi: hasUsableCacheApi()
                    }));
                } catch (_) {}
            }

            function scheduleStatsFlush() {
                statsDirty = true;
                if (statsFlushTimer) return;
                statsFlushTimer = window.setTimeout(flushStats, STATS_FLUSH_DELAY);
            }

            function flushStats() {
                if (statsFlushTimer) {
                    clearTimeout(statsFlushTimer);
                    statsFlushTimer = null;
                }
                if (!statsDirty) return;
                statsDirty = false;
                persistStats();
            }

            function rememberBounded(set, value, maxSize) {
                if (set.has(value)) {
                    set.delete(value);
                }
                set.add(value);
                if (set.size <= maxSize) return;
                const oldest = set.values().next().value;
                set.delete(oldest);
            }

            function scheduleFlush() {
                metadataDirty = true;
                if (flushTimer) return;
                flushTimer = window.setTimeout(flushMetadata, FLUSH_DELAY);
            }

            function flushMetadata() {
                if (flushTimer) {
                    clearTimeout(flushTimer);
                    flushTimer = null;
                }
                if (!metadataDirty) {
                    return;
                }
                metadataDirty = false;
                try {
                    localStorage.setItem(METADATA_KEY, JSON.stringify(Object.fromEntries(metadataMap)));
                } catch (_) {}
            }

            function touchItem(url) {
                metadataMap.set(url, Date.now());
                scheduleFlush();
            }

            function isFresh(url) {
                if (forceRevalidateUrls.has(url)) return false;
                const timestamp = metadataMap.get(url);
                if (!timestamp) return false;
                return (Date.now() - timestamp) < getRevalidateTTL();
            }

            function triggerMaintenance() {
                if ('requestIdleCallback' in window) {
                    window.requestIdleCallback(pruneCache);
                } else {
                    window.setTimeout(pruneCache, 5000);
                }
            }

            async function pruneCache() {
                if (!hasUsableCacheApi()) return;
                try {
                    const cache = await caches.open(CACHE_NAME);
                    const keys = await cache.keys();
                    if (keys.length <= MAX_ITEMS) return;

                    const sorted = keys.sort(function (a, b) {
                        return (metadataMap.get(a.url) || 0) - (metadataMap.get(b.url) || 0);
                    });
                    const toDelete = sorted.slice(0, PRUNE_CHUNK);

                    await Promise.all(toDelete.map(async function (req) {
                        metadataMap.delete(req.url);
                        await cache.delete(req);
                    }));
                    scheduleFlush();
                } catch (_) {}
            }

            function isCacheableUrl(url) {
                if (!CACHEABLE_EXTENSIONS.test(url)) return false;
                if (SKIP_URL_PATTERNS.some(function (re) { return re.test(url); })) return false;
                return true;
            }

            function getCacheability(response) {
                const cc = response.headers.get('Cache-Control') || '';
                if (NO_STORE.test(cc)) return false;
                const ct = response.headers.get('Content-Type') || '';
                if (ct && !CACHEABLE_CONTENT_TYPES.test(ct)) return false;
                if (response.status === 206) return false;
                if (!response.ok) return false;
                if (FORCE_REVALIDATE.test(cc)) return 'revalidate';
                return true;
            }

            function installFetchCacheLayer() {
                const hasServiceWorker = 'serviceWorker' in navigator;
                const shouldOverrideFetch = hasUsableCacheApi() && (!hasServiceWorker || !navigator.serviceWorker.controller);
                if (!shouldOverrideFetch || typeof window.fetch !== 'function') return;

                let cachePromise = null;

                function getCache() {
                    if (!cachePromise) {
                        cachePromise = caches.open(CACHE_NAME).catch(function (error) {
                            cachePromise = null;
                            throw error;
                        });
                    }
                    return cachePromise;
                }

                const originalFetch = window.fetch.bind(window);

                function isRequestLike(obj) {
                    return !!obj && typeof obj === 'object' && 'url' in obj && 'method' in obj;
                }

                window.fetch = async function () {
                    const args = Array.prototype.slice.call(arguments);
                    let method = 'GET';
                    let urlStr = '';

                    if (isRequestLike(args[0])) {
                        method = (args[1] && args[1].method) || args[0].method;
                        urlStr = args[0].url;
                    } else {
                        method = (args[1] && args[1].method) || 'GET';
                        try {
                            urlStr = new URL(args[0], location.href).href;
                        } catch (_) {
                            return originalFetch.apply(window, args);
                        }
                    }

                    method = String(method || 'GET').toUpperCase();
                    const cacheMode = (args[1] && args[1].cache) || (isRequestLike(args[0]) && args[0].cache);
                    const isBypass = cacheMode === 'no-cache' || cacheMode === 'reload' || cacheMode === 'no-store';

                    if (method !== 'GET' || !isCacheableUrl(urlStr) || isBypass) {
                        return originalFetch.apply(window, args);
                    }

                    try {
                        const cache = await getCache();
                        const cachedResponse = await cache.match(urlStr);

                        if (cachedResponse) {
                            cacheHits += 1;
                            scheduleStatsFlush();
                            const responseToReturn = cachedResponse.clone();

                            if (!isFresh(urlStr)) {
                                originalFetch.apply(window, args).then(async function (networkResponse) {
                                    const cacheability = getCacheability(networkResponse);
                                    if (!cacheability) return;
                                    if (cacheability === 'revalidate') rememberBounded(forceRevalidateUrls, urlStr, MAX_REVALIDATE_URLS);
                                    await cache.put(urlStr, networkResponse.clone()).catch(function () {
                                        triggerMaintenance();
                                    });
                                    touchItem(urlStr);
                                    if (Math.random() < 0.05) triggerMaintenance();
                                }).catch(function () {});
                            } else {
                                touchItem(urlStr);
                            }

                            return responseToReturn;
                        }

                        cacheMisses += 1;
                        scheduleStatsFlush();
                        const networkResponse = await originalFetch.apply(window, args);
                        const cacheability = getCacheability(networkResponse);
                        if (cacheability) {
                            if (cacheability === 'revalidate') rememberBounded(forceRevalidateUrls, urlStr, MAX_REVALIDATE_URLS);
                            cache.put(urlStr, networkResponse.clone()).then(function () {
                                touchItem(urlStr);
                                if (Math.random() < 0.05) triggerMaintenance();
                            }).catch(function () {
                                triggerMaintenance();
                            });
                        }

                        return networkResponse;
                    } catch (_) {
                        return originalFetch.apply(window, args);
                    }
                };

                if (hasServiceWorker) {
                    navigator.serviceWorker.addEventListener('controllerchange', function () {
                        window.fetch = originalFetch;
                        cachePromise = null;
                    }, { once: true });
                }
            }

            function installSpeculationRules() {
                if (speculationRulesInstalled || document.getElementById(SPECULATION_SCRIPT_ID)) {
                    speculationRulesInstalled = true;
                    return true;
                }
                if (!window.HTMLScriptElement || typeof HTMLScriptElement.supports !== 'function') return false;
                if (!HTMLScriptElement.supports('speculationrules')) return false;

                const conn = navigator.connection;
                if (conn && (conn.saveData || conn.effectiveType === 'slow-2g' || conn.effectiveType === '2g')) return false;

                const downloadExtensions = [
                    '.pdf', '.zip', '.tar', '.gz', '.rar', '.7z', '.exe', '.dmg', '.pkg',
                    '.mp3', '.mp4', '.avi', '.mov', '.wmv', '.flv', '.mkv',
                    '.doc', '.docx', '.xls', '.xlsx', '.ppt', '.pptx',
                    '.iso', '.img', '.bin', '.deb', '.rpm', '.apk'
                ];

                const excludeSelectors = [
                    "a[href^='javascript:']",
                    "a[href^='mailto:']",
                    "a[href^='tel:']",
                    "a[href*='download']",
                    "a[href*='logout']",
                    "a[href*='signout']",
                    "a[href*='log-out']",
                    "a[href*='sign-out']"
                ].concat(downloadExtensions.map(function (ext) {
                    return "a[href$='" + ext + "' i]";
                })).join(', ');

                const rules = {
                    prefetch: [{
                        where: {
                            and: [
                                { href_matches: '/*' },
                                { not: { selector_matches: excludeSelectors } }
                            ]
                        },
                        eagerness: 'moderate'
                    }],
                    prerender: [{
                        where: {
                            and: [
                                { selector_matches: "a[rel='next'], link[rel='next']" },
                                { not: { selector_matches: excludeSelectors } }
                            ]
                        },
                        eagerness: 'moderate'
                    }]
                };

                const script = document.createElement('script');
                script.id = SPECULATION_SCRIPT_ID;
                script.type = 'speculationrules';
                script.textContent = JSON.stringify(rules);
                (document.head || document.documentElement).appendChild(script);
                speculationRulesInstalled = true;
                return true;
            }

            function installPreconnectOnHover() {
                const connected = new Map();
                const currentOrigin = location.origin;
                const maxPreconnects = 8;

                function preconnect(origin) {
                    if (connected.has(origin) || origin === currentOrigin) return;
                    if (!document.head) return;
                    if (connected.size >= maxPreconnects) {
                        const oldest = connected.keys().next().value;
                        const oldLink = connected.get(oldest);
                        if (oldLink) oldLink.remove();
                        connected.delete(oldest);
                    }
                    const hint = document.createElement('link');
                    hint.rel = 'preconnect';
                    hint.crossOrigin = 'anonymous';
                    hint.href = origin;
                    document.head.appendChild(hint);
                    connected.set(origin, hint);
                }

                document.addEventListener('pointerenter', function (event) {
                    const link = getClosestLinkTarget(event.target);
                    if (!link) return;
                    try {
                        const url = new URL(link.href);
                        if (url.protocol === 'http:' || url.protocol === 'https:') {
                            preconnect(url.origin);
                        }
                    } catch (_) {}
                }, { passive: true, capture: true });
            }

            function installFallbackNavigationWarmup() {
                const conn = navigator.connection;
                if (conn && (conn.saveData || conn.effectiveType === 'slow-2g' || conn.effectiveType === '2g')) return;

                const prefetched = new Set();

                function isEligible(link) {
                    if (!link || !link.href) return false;

                    let url;
                    try {
                        url = new URL(link.href);
                    } catch (_) {
                        return false;
                    }

                    if (url.origin !== location.origin) return false;
                    if (url.protocol !== 'http:' && url.protocol !== 'https:') return false;
                    if ((url.pathname + url.search) === (location.pathname + location.search)) return false;

                    const hrefAttr = link.getAttribute('href') || '';
                    if (/\.(pdf|zip|tar|gz|exe|dmg|pkg|mp[34]|mov|doc|xls|ppt)(\?|$)/i.test(hrefAttr)) return false;
                    if (/download|logout|signout|log-out|sign-out/i.test(hrefAttr)) return false;
                    if (link.hasAttribute('download')) return false;

                    return true;
                }

                function warmNavigation(href) {
                    if (prefetched.has(href)) return;
                    rememberBounded(prefetched, href, MAX_WARMED_URLS);

                    fetch(href, {
                        method: 'GET',
                        credentials: 'include',
                        mode: 'same-origin',
                        cache: 'force-cache'
                    }).catch(function () {});
                }

                document.addEventListener('mousedown', function (event) {
                    if (event.button !== 0) return;
                    const link = getClosestLinkTarget(event.target);
                    if (isEligible(link)) warmNavigation(link.href);
                }, { passive: true, capture: true });

                document.addEventListener('touchstart', function (event) {
                    const link = getClosestLinkTarget(event.target);
                    if (isEligible(link)) warmNavigation(link.href);
                }, { passive: true, capture: true });
            }

            function installFontDisplaySwap() {
                function patchStyleSheets() {
                    Array.prototype.forEach.call(document.styleSheets, function (sheet) {
                        try {
                            const rules = sheet.cssRules || sheet.rules;
                            if (!rules) return;
                            Array.prototype.forEach.call(rules, function (rule) {
                                if (window.CSSFontFaceRule && rule instanceof CSSFontFaceRule && !rule.style.fontDisplay) {
                                    rule.style.fontDisplay = 'swap';
                                }
                            });
                        } catch (_) {}
                    });
                }

                patchStyleSheets();

                const observer = new MutationObserver(function (mutations) {
                    const hasNewStyles = mutations.some(function (mutation) {
                        return Array.prototype.some.call(mutation.addedNodes, function (node) {
                            return node && node.nodeType === 1 && (node.tagName === 'LINK' || node.tagName === 'STYLE');
                        });
                    });

                    if (hasNewStyles) {
                        requestAnimationFrame(patchStyleSheets);
                    }
                });

                if (document.head) observer.observe(document.head, { childList: true });

                if (document.body) {
                    observer.observe(document.body, { childList: true });
                } else {
                    window.addEventListener('DOMContentLoaded', function () {
                        if (document.body) observer.observe(document.body, { childList: true });
                    }, { once: true });
                }

                window.setTimeout(function () {
                    observer.disconnect();
                }, FONT_OBSERVER_LIFETIME_MS);
            }

            async function handleCommand(type) {
                if (type === 'purge-cache') {
                    if (hasUsableCacheApi()) {
                        try {
                            await caches.delete(CACHE_NAME);
                        } catch (_) {}
                    }
                    metadataMap.clear();
                    forceRevalidateUrls.clear();
                    metadataDirty = false;
                    if (flushTimer) {
                        clearTimeout(flushTimer);
                        flushTimer = null;
                    }
                    try {
                        localStorage.removeItem(METADATA_KEY);
                    } catch (_) {}
                    cacheHits = 0;
                    cacheMisses = 0;
                    statsDirty = false;
                    persistStats();
                    alert('Quicksilver Safari cache purged for this site.');
                    return;
                }

                if (type === 'show-stats') {
                    let itemCount = 0;
                    let estimatedSize = 0;

                    if (hasUsableCacheApi()) {
                        try {
                            const cache = await caches.open(CACHE_NAME);
                            const keys = await cache.keys();
                            itemCount = keys.length;
                            const sample = keys.slice(0, 20);
                            let sampleSize = 0;
                            for (const req of sample) {
                                const res = await cache.match(req);
                                if (!res) continue;
                                const blob = await res.blob();
                                sampleSize += blob.size;
                            }
                            if (sample.length > 0) {
                                estimatedSize = (sampleSize / sample.length) * itemCount;
                            }
                        } catch (_) {}
                    }

                    const total = cacheHits + cacheMisses;
                    const hitRate = total > 0 ? ((cacheHits / total) * 100).toFixed(1) : 'N/A';
                    const sizeStr = estimatedSize > 1048576
                        ? (estimatedSize / 1048576).toFixed(1) + ' MB'
                        : (estimatedSize / 1024).toFixed(0) + ' KB';
                    const connection = getConnectionInfo().effectiveType;

                    alert(
                        'Quicksilver Safari Stats\\n' +
                        '-------------------------\\n' +
                        'Cached items: ' + itemCount + '\\n' +
                        'Estimated size: ' + sizeStr + '\\n' +
                        'Hits: ' + cacheHits + ' | Misses: ' + cacheMisses + '\\n' +
                        'Hit rate: ' + hitRate + '%\\n' +
                        'TTL: ' + (getRevalidateTTL() / 60000).toFixed(0) + ' min\\n' +
                        'Connection: ' + connection + '\\n' +
                        'Secure context: ' + (window.isSecureContext ? 'yes' : 'no') + '\\n' +
                        'Cache API: ' + (hasUsableCacheApi() ? 'available' : 'unavailable')
                    );
                }
            }

            function initWhenReady(initFn) {
                if (document.readyState === 'complete' || document.readyState === 'interactive') {
                    initFn();
                } else {
                    window.addEventListener('DOMContentLoaded', initFn, { once: true });
                }
            }

            loadMetadata();
            persistStats();
            installFetchCacheLayer();
            window.addEventListener('pagehide', function () {
                flushMetadata();
                flushStats();
            });
            window.addEventListener(EVENT_PREFIX + ':command', function (event) {
                const type = event && event.detail ? event.detail.type : '';
                handleCommand(type);
            });

            initWhenReady(installPreconnectOnHover);
            initWhenReady(function () {
                if (!installSpeculationRules()) {
                    installFallbackNavigationWarmup();
                }
            });
            initWhenReady(installFontDisplaySwap);
        } + ')();';

        const script = document.createElement('script');
        script.id = injectId;
        script.textContent = runtimeSource;
        (document.documentElement || document.head || document.body).appendChild(script);
        script.remove();
    }

    installMenuCommands();
    installConsoleFallback();
    injectRuntime();
})();
